{
  "name": "@clawdb/mcp-adapter",
  "version": "0.1.5",
  "type": "module",
  "bin": {
    "clawdb-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
