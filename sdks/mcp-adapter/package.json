  },
  "dependencies": {
    "@clawdb/sdk": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsup": "^8.2.4",
    "vitest": "^1.6.1"
  },
  "publishConfig": {
    "access": "public"
  }
