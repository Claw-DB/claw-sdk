{
  "name": "@clawdb/sdk",
  "version": "0.1.13",
  "description": "Zero-config database for AI agents.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Claw-DB/claw-sdk",
    "directory": "sdks/typescript"
  },
  "keywords": [
    "ai",
    "agents",
    "database",
    "memory",
    "clawdb",
    "langchain",
    "openai",
    "vercel-ai",
    "mcp"
  ],
  "type": "commonjs",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "proto",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@grpc/grpc-js": ">=1.10.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.0",
    "@grpc/proto-loader": "^0.7.0",
    "@clawdb/errors": "workspace:*",
    "@clawdb/proto": "workspace:*",
    "@clawdb/types": "workspace:*",
    "nice-grpc": "^2.1.0",
    "nice-grpc-web": "^3.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.6.1",
    "tsup": "^8.2.4",
    "vitest": "^1.6.1"
  }
}
